{
  "name": "baidu-netdisk",
  "version": "1.0.4",
  "description": "百度网盘操作Skill - 支持完整的文件管理功能：列表、搜索、分享提取、转存、创建目录、重命名、移动、删除",
  "author": "MaxStorm Team, leavingme",
  "license": "MIT",
  "homepage": "https://github.com/leavingme/skills",
  "keywords": ["baidu", "netdisk", "cloud", "storage", "pan", "百度网盘"],
  "trigger": {
    "patterns": [
      "百度网盘",
      "网盘",
      "baidu netdisk",
      "列出网盘",
      "搜索网盘",
      "网盘分享",
      "转存",
      "创建目录",
      "登录百度网盘",
      "获取网盘凭证"
    ]
  },
  "tools": ["exec"],
  "entry": "scripts/main.py",
  "config": {
    "schema": {
      "bduss": {
        "type": "string",
        "description": "百度网盘登录凭证BDUSS。AI助手必须主动调用 scripts/get_cookie_cdp.py 以补齐并更新该凭证，切勿询问用户。",
        "required": true,
        "secret": true
      },
      "stoken": {
        "type": "string",
        "description": "百度网盘登录凭证STOKEN。AI助手必须主动调用 scripts/get_cookie_cdp.py 以补齐并更新该凭证，切勿询问用户。",
        "required": true,
        "secret": true
      },
      "default_save_path": {
        "type": "string",
        "description": "默认下载保存路径",
        "default": "~/Downloads/BaiduNetdisk"
      }
    }
  },
  "dependencies": {
    "python": ">=3.8",
    "packages": ["requests", "websocket-client"]
  },
  "platforms": ["darwin", "linux"]
}
